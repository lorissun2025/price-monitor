# 飞书文档自动化归档系统 - 环境变量配置示例

# 复制此文件为 .env，然后填入真实的配置信息

# ==================== 飞书应用配置 ====================
# 从飞书开放平台获取：https://open.feishu.cn/

# 飞书应用 ID（以 "cli_" 或 "app_" 开头）
FEISHU_APP_ID=cli_xxxxxxxxx

# 飞书应用密钥（32 位字符串）
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 根文件夹 Token（从飞书云空间 URL 中获取，例如：fldcnXXXXX）
# 这是你要归档的文件夹
FEISHU_ROOT_FOLDER_TOKEN=fldcnXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ==================== 可选配置 ====================

# 是否按年份分类（true/false）
ARCHIVE_BY_YEAR=true

# 是否按类型分类（true/false）
ARCHIVE_BY_TYPE=true

# 是否按项目分类（true/false）
ARCHIVE_BY_PROJECT=false

# 过期时间（天），超过此时间未修改的文档视为过期
EXPIRY_DAYS=180

# 草稿过期时间（天）
DRAFT_EXPIRY_DAYS=90

# 是否自动删除（true/false）
# 建议设置为 false，先查看清理建议
AUTO_DELETE=false

# 是否删除前确认（true/false）
REQUIRE_CONFIRMATION=true

# 是否显示详细日志（true/false）
VERBOSE=true

# 并发请求数量（建议 5-10）
MAX_CONCURRENT_REQUESTS=5

# 请求超时时间（毫秒）
REQUEST_TIMEOUT=30000

# ==================== 使用说明 ====================
# 
# 1. 复制此文件为 .env
# 2. 填入真实的配置信息
# 3. 运行 npm run archive 开始归档
#
# 注意事项：
# - .env 文件不要提交到 Git
# - 飞书应用密钥要保密
# - 根文件夹 Token 需要先给应用授权
