import random
from typing import Dict, List

class DropSystem:
    def __init__(self):
        self.base_weights = {
            'epic': 0.05,
            'rare': 0.15,
            'common': 0.60,
            'materials': 0.20
        }
        self.player_drop_history = {}
        
    def calculate_adjusted_weights(self, player_id: str, context: Dict) -> Dict[str, float]:
        """计算调整后的权重"""
        weights = self.base_weights.copy()
        
        # 获取玩家历史
        history = self.player_drop_history.get(player_id, {'drops': [], 'consecutive_common': 0})
        
        # 连续失败保底
        if history['consecutive_common'] > 10:
            boost_factor = 1.0 + (history['consecutive_common'] - 10) * 0.05
            weights['epic'] *= boost_factor
            weights['rare'] *= boost_factor
        
        # 等级匹配调整
        player_level = context.get('player_level', 1)
        mob_level = context.get('mob_level', 1)
        level_diff = abs(player_level - mob_level)
        if level_diff > 5:
            penalty = max(0.3, 1.0 - level_diff * 0.05)
            weights['epic'] *= penalty
            weights['rare'] *= penalty
        
        # 归一化
        total = sum(weights.values())
        normalized = {k: v/total for k, v in weights.items()}
        
        return normalized
    
    def pseudo_random_drop(self, player_id: str, context: Dict) -> str:
        """伪随机掉落"""
        # 计算调整权重
        weights = self.calculate_adjusted_weights(player_id, context)
        
        # 加权随机选择
        options = list(weights.keys())
        probabilities = list(weights.values())
        drop_type = random.choices(options, weights=probabilities, k=1)[0]
        
        # 更新历史
        history = self.player_drop_history.setdefault(player_id, {'drops': [], 'consecutive_common': 0})
        history['drops'].append(drop_type)
        
        # 更新连续计数
        if drop_type in ['common', 'materials']:
            history['consecutive_common'] += 1
        else:
            history['consecutive_common'] = 0
        
        # 限制历史记录长度
        if len(history['drops']) > 100:
            history['drops'].pop(0)
        
        return drop_type
        `
